{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://propstore.dev/schema/form.schema.json",
  "title": "Form Definition",
  "description": "Schema for propstore form definition YAML files (forms/*.yaml).",
  "type": "object",
  "required": ["name", "dimensionless"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Form name, must match the filename stem.",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "dimensionless": {
      "type": "boolean",
      "description": "Whether this form represents a dimensionless quantity."
    },
    "base": {
      "type": "string",
      "description": "Base form type (e.g. 'ratio').",
      "enum": ["ratio"]
    },
    "unit_symbol": {
      "type": ["string", "null"],
      "description": "Primary unit symbol for this form (null for dimensionless forms)."
    },
    "qudt": {
      "type": ["string", "null"],
      "description": "QUDT IRI for the unit (e.g. 'qudt:HZ')."
    },
    "parameters": {
      "type": "object",
      "description": "Form-specific parameters."
    },
    "common_alternatives": {
      "type": "array",
      "description": "Alternative unit conversions.",
      "items": {
        "type": "object",
        "required": ["unit", "type"],
        "properties": {
          "unit": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["multiplicative", "affine", "logarithmic"]
          },
          "multiplier": {
            "type": "number"
          },
          "offset": {
            "type": "number"
          },
          "base": {
            "type": "number"
          },
          "divisor": {
            "type": "number"
          },
          "reference": {
            "type": "number"
          }
        },
        "additionalProperties": false
      }
    },
    "kind": {
      "type": "string",
      "description": "Kind of quantity this form represents.",
      "enum": ["quantity", "category", "boolean", "structural"]
    },
    "note": {
      "type": "string",
      "description": "Human-readable note about this form."
    },
    "dimensions": {
      "type": "object",
      "description": "Base dimension exponents. Keys are dimension symbols (e.g. L, M, T for physics; Currency, Quantity for economics); values are integer exponents. Any string key is valid — the dimension basis is domain-defined.",
      "propertyNames": {
        "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "integer"
      }
    }
  },
  "additionalProperties": false
}
