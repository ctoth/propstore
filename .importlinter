[importlinter]
root_package = propstore
include_external_packages = True

# One-way layer dependencies (CLAUDE.md "Architectural Layers"): a layer may
# import the layers below it, never above. The CLI and web presentation adapters
# sit over the Phase-10-0 render owner layer (``app``), which sits over ``world``.
[importlinter:contract:propstore-layers]
name = propstore one-way layer dependencies
type = layers
layers =
    cli
    app
    world
    aspic_bridge : praf
    heuristic
    source
    storage
containers = propstore

# The web package is the top of the presentation stack: nothing in the owner
# layers imports it. The ``pks web`` launcher in the CLI is the sole entry point
# that pulls it in, so ``cli`` is deliberately excluded from the sources below.
[importlinter:contract:web-is-top-presentation]
name = web presentation adapter is never imported by owner layers
type = forbidden
source_modules =
    propstore.app
    propstore.world
    propstore.aspic_bridge
    propstore.praf
    propstore.heuristic
    propstore.source
    propstore.storage
    propstore.core
forbidden_modules =
    propstore.web

# Substrate-boundary rule: the source-of-truth storage layer and the semantic
# core never reach UP into the argumentation / world / presentation layers.
# The one ``ignore_imports`` exception is the tracked, pre-existing
# core.analyzers -> praf entanglement (docs/gaps.md): core.analyzers and
# praf.projection import each other, so relocating the PrAF projection out of
# core is a separate refactor. The rule still catches any NEW substrate->upward
# import; only this one edge is grandfathered.
[importlinter:contract:substrate-never-imports-upward]
name = storage and core never import the argumentation / world / cli layers
type = forbidden
source_modules =
    propstore.storage
    propstore.core
forbidden_modules =
    propstore.world
    propstore.aspic_bridge
    propstore.praf
    propstore.cli
ignore_imports =
    propstore.core.analyzers -> propstore.praf
